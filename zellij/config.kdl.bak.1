// Zellij config - svfabio

theme "crimson"

themes {
    crimson {
        fg "#F5E6D3"
        bg "#0D0D0D"
        black "#111111"
        red "#E00000"
        green "#9B1111"
        yellow "#CC0000"
        blue "#1E1E1E"
        magenta "#6B0000"
        cyan "#2D2D2D"
        white "#F5E6D3"
        orange "#FF3C3C"
    }
}

pane_frames true
default_shell "fish"
scroll_buffer_size 10000
copy_on_select true

ui {
    pane_frames {
        rounded_corners true
        hide_session_name false
    }
}
